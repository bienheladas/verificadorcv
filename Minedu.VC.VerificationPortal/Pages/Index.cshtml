@page
@model IndexModel
@{
    ViewData["Title"] = "Portal de Verificación de Certificados de Estudio";

    var verifiers = new Dictionary<string, (string Nombre, string Cargo, string Logo)>
    {
        ["empresa"]        = ("TechPerú Empleos S.A.C.", "Área de Recursos Humanos", "/assets/empresa-logo.svg"),
        ["evento"]         = ("Congreso Nacional de Educación 2025", "Secretaría de Registro", "/assets/empresa-logo.svg"),
        ["pae"]            = ("Proveedor Qali Warma – Camión C-042", "Programa de Alimentación Escolar (PAE)", "/assets/empresa-logo.svg"),
    };

    var perfil = Model.Profile ?? "empresa";
    var (verNombre, verCargo, verLogo) = verifiers.TryGetValue(perfil, out var v)
        ? v : ("TechPerú Empleos S.A.C.", "Área de Recursos Humanos", "/assets/empresa-logo.svg");
}

<div class="container mt-5 text-center">

    @if (!string.IsNullOrEmpty(Model.Profile))
    {
        <div class="d-flex align-items-center justify-content-center gap-3 mb-4 p-3 border rounded bg-light">
            <img src="@verLogo" alt="Logo @verNombre" style="width:64px;height:64px;object-fit:contain;" />
            <div class="text-start">
                <div class="fw-bold fs-5">@verNombre</div>
                <div class="text-muted small">@verCargo</div>
                <div class="text-muted small">Verificación de credenciales educativas</div>
            </div>
        </div>
    }

    <h2 class="mb-4">Portal de Verificación de Credenciales</h2>
    <p class="text-muted mb-4">Seleccione el tipo de verificación que desea realizar</p>

    <form method="post" class="w-100">
        <div class="d-flex justify-content-center gap-4 flex-wrap mt-3">

            <button type="submit" name="profile" value="empresa"
                    class="verify-card border-0 bg-white shadow-sm rounded-4 d-flex flex-column align-items-center justify-content-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:80px;height:80px;background:#e8f0fe;">
                    <i class="bi bi-building" style="font-size:2.2rem;color:#2563eb;"></i>
                </div>
                <div class="text-center">
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">Empresa</div>
                    <div class="text-muted mt-1" style="font-size:.82rem;">Verificación laboral</div>
                </div>
            </button>

            <button type="submit" name="profile" value="evento"
                    class="verify-card border-0 bg-white shadow-sm rounded-4 d-flex flex-column align-items-center justify-content-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:80px;height:80px;background:#dcfce7;">
                    <i class="bi bi-calendar-event" style="font-size:2.2rem;color:#16a34a;"></i>
                </div>
                <div class="text-center">
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">Evento</div>
                    <div class="text-muted mt-1" style="font-size:.82rem;">Control de acceso</div>
                </div>
            </button>

            <button type="submit" name="profile" value="pae"
                    class="verify-card border-0 bg-white shadow-sm rounded-4 d-flex flex-column align-items-center justify-content-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center overflow-hidden"
                     style="width:80px;height:80px;background:#fff5f5;">
                    <img src="/assets/pae-logo.png" alt="PAE"
                         style="width:68px;height:auto;object-fit:contain;" />
                </div>
                <div class="text-center">
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">Alimentación Escolar</div>
                    <div class="text-muted mt-1" style="font-size:.82rem;">Entrega de desayunos</div>
                </div>
            </button>

        </div>
    </form>

    <style>
        .verify-card {
            width: 220px;
            min-height: 200px;
            padding: 2rem 1.5rem;
            cursor: pointer;
            transition: box-shadow .2s, transform .15s;
        }
        .verify-card:hover {
            box-shadow: 0 10px 28px rgba(0,0,0,.13) !important;
            transform: translateY(-4px);
        }
        .verify-card:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(0,0,0,.08) !important;
        }
    </style>

    @if (ViewData["Error"] != null)
    {
        <div class="alert alert-danger mt-3">@ViewData["Error"]</div>
    }

    @if (Model.QrImageBase64 is not null)
    {
        <div class="mt-5">
            <h5>Escanee este código con su billetera Inji</h5>
            <img src="data:image/png;base64,@Model.QrImageBase64" class="shadow rounded p-3" style="width:220px;" />

            @if (Model.Result == null)
            {
                <p class="text-muted mt-2">Esperando presentación de la billetera...</p>
                <a href="?sessionId=@Model.SessionId&profile=@Model.Profile" class="btn btn-outline-primary mt-2">
                    🔄 Verificar resultado
                </a>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.PresentationUri))
    {
        <div style="margin-top:20px; padding:12px; border:1px solid #ccc; background:#f9f9f9;">
            <strong>URI de presentación (real – encoded)</strong>
            <pre style="white-space:pre-wrap; word-break:break-all;">@Model.PresentationUri</pre>

            <strong>URI de presentación (legible – decoded)</strong>
            <pre style="white-space:pre-wrap; word-break:break-all; background:#eef;">@Model.PresentationUriDecoded</pre>

            <button onclick="navigator.clipboard.writeText('@Model.PresentationUri')">
                Copiar URI real
            </button>
        </div>
    }

    @if (Model.Result != null)
    {
        <div class="card mt-4">
            <div class="card-body">
                <h3 class="card-title">Resultado de la Verificación</h3>

                <p>
                    <strong>Estado general:</strong>
                    @if (Model.Result.Valid)
                    {
                        <span class="text-success">✅ Credencial válida</span>
                    }
                    else
                    {
                        <span class="text-danger">❌ Credencial inválida</span>
                    }
                </p>

                @if (Model.Result.Valid && Model.Result.Summary != null && Model.Result.Summary.TryGetValue("Nombres", out var nombreObj))
                {
                    var nombre = nombreObj?.ToString();
                    if (!string.IsNullOrWhiteSpace(nombre))
                    {
                        @if (Model.Profile == "evento")
                        {
                            var yaRegistrado = Model.Result.Summary.TryGetValue("YaRegistrado", out var yr) && yr?.ToString() == "True";
                            var registradoEn = Model.Result.Summary.TryGetValue("RegistradoEn", out var re) ? re?.ToString() : null;
                            @if (yaRegistrado)
                            {
                                <div class="alert alert-warning py-2 px-3 mb-2">
                                    ⚠️ <strong>@nombre</strong> — asistencia ya registrada el @registradoEn.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-success py-2 px-3 mb-2">
                                    ✅ Bienvenido/a, <strong>@nombre</strong>. Su asistencia al evento ha sido registrada.
                                </div>
                            }
                        }
                        else if (Model.Profile == "pae")
                        {
                            var yaRecogio = Model.Result.Summary.TryGetValue("YaRecogio", out var yrp) && yrp?.ToString() == "True";
                            var camion    = Model.Result.Summary.TryGetValue("NumeroCamion", out var cam) ? cam?.ToString() : "C-042";
                            var hora      = Model.Result.Summary.TryGetValue("HoraRecojo",   out var hr)  ? hr?.ToString()  : "";
                            @if (yaRecogio)
                            {
                                <div class="alert alert-warning py-2 px-3 mb-2">
                                    ⚠️ <strong>@nombre</strong> — el desayuno ya fue retirado hoy. No se puede entregar nuevamente.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-success py-2 px-3 mb-2">
                                    🍽️ Desayuno entregado a <strong>@nombre</strong> a las <strong>@hora</strong> — Camión <strong>@camion</strong>.
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-success py-2 px-3 mb-2">
                                👋 Bienvenido/a, <strong>@nombre</strong>. Su postulación ha sido recibida correctamente.
                            </div>
                        }
                    }
                }
                else if (!Model.Result.Valid)
                {
                    @if (Model.Profile == "evento")
                    {
                        var dniConsulta = Model.Result.Summary != null && Model.Result.Summary.TryGetValue("DNI", out var dniObj) ? dniObj?.ToString() : null;
                        <div class="alert alert-danger py-2 px-3 mb-2">
                            ❌ No fue posible registrar la asistencia. El DNI <strong>@(dniConsulta ?? "—")</strong> no figura en la lista de invitados del evento.
                        </div>
                    }
                    else if (Model.Profile == "pae")
                    {
                        <div class="alert alert-danger py-2 px-3 mb-2">
                            ❌ No se puede entregar el desayuno. @Model.Result.Reason
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger py-2 px-3 mb-2">
                            ❌ No fue posible procesar su postulación. La credencial presentada no cumple con los requisitos solicitados.
                        </div>
                    }
                }

                <p><strong>Motivo:</strong> @Model.Result.Reason</p>

                @if (Model.Result.Summary != null && Model.Result.Summary.ContainsKey("status"))
                {
                    var estado = Model.Result.Summary["status"].ToString();
                    <p><strong>Estado de la credencial:</strong> @(estado == "revoked" ? "❌ Revocada" : "✅ Activa")</p>
                }

                <h5 class="mt-3">Verificaciones individuales:</h5>
                <ul class="list-unstyled">
                    @foreach (var check in Model.Result.Checks)
                    {
                        <li>@(check.Passed ? "✅" : "❌") <strong>@check.Name</strong>: @check.Message</li>
                    }
                </ul>
            </div>
        </div>
    }
</div>
